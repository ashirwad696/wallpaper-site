<!DOCTYPE html>
<html>
<head>
  <title>Minimalist Wallpapers</title>
  <style>
    body { background:#111; color:#fff; font-family:Arial; text-align:center; }
    h1 { color:#0ff; text-shadow:0 0 15px #0ff,0 0 30px #f0f; }
    .gallery { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:20px; padding:20px; }
    .gallery img { width:100%; border-radius:10px; box-shadow:0 0 20px rgba(0,255,255,0.6),0 0 40px rgba(255,0,255,0.4); filter:blur(2px) brightness(1.1); transition:transform 0.3s,filter 0.3s; }
    .gallery img:hover { transform:scale(1.1); filter:blur(0px) brightness(1.4); }
  </style>
</head>
<body>
  <h1>Minimalist Wallpapers</h1>
  <div class="gallery">
    <img src="wallpaper1.jpg" alt="Minimalist 1">
    <img src="wallpaper2.jpg" alt="Minimalist 2">
  </div>
</body>
</html>
